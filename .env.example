DISCORD_TOKEN=YOUR_DISCORD_BOT_TOKEN
TRANSCRIPT_CHANNEL_ID=123456789012345678
FWS_BASE_URL=http://localhost:8000
# Codex セッション保存先（デフォルト: data/codex_sessions.json）
CODEX_STATE_PATH=data/codex_sessions.json
# スレッド名生成に Gemini を使う場合のみ設定（未設定でも動作します）
GEMINI_API_KEY=YOUR_GEMINI_API_KEY
# Codex / LLM 設定（デフォルトは gpt-5.1 と reasoning minimal）
CODEX_MODEL=gpt-5.1
CODEX_REASONING_EFFORT=minimal
